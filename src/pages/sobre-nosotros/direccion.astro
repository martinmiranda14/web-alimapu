---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/ui/HeroSection.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { assetPath } from '../../utils/paths';

const allMembers = await getCollection('integrantes', ({ data }) => data.isActive && data.section === 'direccion');
const directors = allMembers.sort((a, b) => a.data.order - b.data.order);
const featuredDirector = directors.find((m) => m.data.featured);
const otherDirectors = directors.filter((m) => !m.data.featured);
---

<BaseLayout
  title="Dirección Musical"
  description="Conoce al equipo de dirección musical de la Orquesta Filarmónica Alimapu."
>
  <HeroSection title="Dirección Musical" height="sm" />

  {featuredDirector && (
    <Section bg="white">
      <SectionHeading title="Directora Principal" />
      <div class="max-w-3xl mx-auto scroll-reveal">
        <div class="flex flex-col md:flex-row items-center gap-8 bg-surface-50 rounded-2xl p-8">
          {featuredDirector.data.photo ? (
            <img
              src={assetPath(featuredDirector.data.photo)}
              alt={featuredDirector.data.name}
              class="w-40 h-40 rounded-full object-cover shrink-0 shadow-lg"
              style={featuredDirector.data.photoPosition ? `object-position: ${featuredDirector.data.photoPosition}` : ''}
            />
          ) : (
            <div class="w-40 h-40 rounded-full bg-primary-100 flex items-center justify-center shrink-0 shadow-lg">
              <span class="text-primary-700 font-bold text-4xl">
                {featuredDirector.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
              </span>
            </div>
          )}
          <div class="text-center md:text-left">
            <h3 class="font-display text-2xl font-bold text-primary-950">
              {featuredDirector.data.name}
            </h3>
            <p class="text-accent-600 font-medium mt-1">{featuredDirector.data.instrument}</p>
            {featuredDirector.data.bio && (
              <div class="text-gray-600 mt-4 leading-relaxed space-y-3" set:html={featuredDirector.data.bio.split('\n').map(p => `<p>${p}</p>`).join('')} />
            )}
          </div>
        </div>
      </div>
    </Section>
  )}

  {otherDirectors.length > 0 && (
    <Section bg="light">
      <SectionHeading title="Directores Asistentes" />
      <div class="grid gap-6 max-w-3xl mx-auto">
        {otherDirectors.map((member) => (
          <div class="scroll-reveal">
            <div class="flex flex-col md:flex-row items-center gap-8 bg-white rounded-2xl p-8 shadow-sm">
              {member.data.photo ? (
                <img
                  src={assetPath(member.data.photo)}
                  alt={member.data.name}
                  class="w-40 h-40 rounded-full object-cover shrink-0 shadow-lg"
                  style={member.data.photoPosition ? `object-position: ${member.data.photoPosition}` : ''}
                  loading="lazy"
                />
              ) : (
                <div class="w-40 h-40 rounded-full bg-primary-100 flex items-center justify-center shrink-0 shadow-lg">
                  <span class="text-primary-700 font-bold text-4xl">
                    {member.data.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
                  </span>
                </div>
              )}
              <div class="text-center md:text-left">
                <h3 class="font-display text-2xl font-bold text-primary-950">
                  {member.data.name}
                </h3>
                <p class="text-accent-600 font-medium mt-1">{member.data.instrument}</p>
                {member.data.bio && (
                  <div class="text-gray-600 mt-4 leading-relaxed space-y-3" set:html={member.data.bio.split('\n').map(p => `<p>${p}</p>`).join('')} />
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </Section>
  )}
</BaseLayout>
