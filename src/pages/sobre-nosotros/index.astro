---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/ui/HeroSection.astro';
import Section from '../../components/ui/Section.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { breadcrumbSchema } from '../../utils/schema';

const pages = await getCollection('paginas');
const historia = pages.find((p) => p.id === 'historia');
const resumen = historia?.data.resumen || [];

const schema = breadcrumbSchema([
  { name: 'Inicio', url: 'https://orquestaalimapu.cl/' },
  { name: 'Sobre Nosotros', url: 'https://orquestaalimapu.cl/sobre-nosotros/' },
]);
---

<BaseLayout
  title="Sobre Nosotros"
  description="Conoce la historia, misión y visión de la Orquesta Filarmónica Alimapu, agrupación profesional de la región de Valparaíso."
  schema={schema}
>
  <HeroSection
    title="Sobre Nosotros"
    subtitle="Conoce nuestra historia y compromiso cultural"
    height="sm"
  />

  <!-- Misión -->
  <Section bg="white">
    <div class="max-w-3xl mx-auto scroll-reveal">
      <SectionHeading title="Misión" align="center" />
      <p class="text-gray-600 text-lg leading-relaxed text-center">
        Somos una agrupación profesional, autogestionada y autónoma, comprometida con el
        desarrollo humano y cultural de la región de Valparaíso. Buscamos transformar los
        paradigmas tradicionales, promoviendo la inclusión y el acceso universal a la música clásica.
      </p>
    </div>
  </Section>

  <!-- Visión -->
  <Section bg="light">
    <div class="max-w-3xl mx-auto scroll-reveal">
      <SectionHeading title="Visión" align="center" />
      <p class="text-gray-600 text-lg leading-relaxed text-center">
        Aspiramos a ser un referente artístico destacado por nuestra excelencia musical y
        compromiso social. Deseamos representar la diversidad y riqueza multicultural de la
        región de Valparaíso, proyectándonos nacional e internacionalmente como motor de
        desarrollo cultural.
      </p>
    </div>
  </Section>

  <!-- Historia -->
  <Section bg="white">
    <div class="max-w-3xl mx-auto scroll-reveal">
      <SectionHeading title="Historia" align="center" />
      <div class="space-y-6 text-gray-600 text-lg leading-relaxed">
        {resumen.map((parrafo) => (
          <p set:html={parrafo.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
        ))}
      </div>
      <div class="mt-6 text-center">
        <a
          href={`${import.meta.env.BASE_URL}sobre-nosotros/historia/`}
          class="text-accent-600 hover:text-accent-500 font-medium transition-colors"
        >
          Conocer nuestra historia completa &rarr;
        </a>
      </div>
    </div>
  </Section>

  <!-- Links a sub-páginas -->
  <Section bg="light">
    <SectionHeading title="Conoce más" align="center" />
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 max-w-4xl mx-auto">
      {[
        { title: 'Historia', href: `${import.meta.env.BASE_URL}sobre-nosotros/historia/`, desc: 'Nuestro recorrido desde 2017' },
        { title: 'Equipo Directivo', href: `${import.meta.env.BASE_URL}sobre-nosotros/equipo/`, desc: 'Las personas detrás del proyecto' },
        { title: 'Integrantes', href: `${import.meta.env.BASE_URL}sobre-nosotros/integrantes/`, desc: 'Nuestros músicos' },
        { title: 'Dirección', href: `${import.meta.env.BASE_URL}sobre-nosotros/direccion/`, desc: 'Dirección musical' },
        { title: 'Dossier', href: `${import.meta.env.BASE_URL}sobre-nosotros/dossier/`, desc: 'Información institucional' },
      ].map((link) => (
        <a
          href={link.href}
          class="scroll-reveal group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all p-6 text-center"
        >
          <h3 class="font-display text-lg font-bold text-primary-950 group-hover:text-primary-700 transition-colors">
            {link.title}
          </h3>
          <p class="mt-2 text-gray-600 text-sm">{link.desc}</p>
        </a>
      ))}
    </div>
  </Section>
</BaseLayout>
