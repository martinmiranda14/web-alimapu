---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/ui/HeroSection.astro';
import Section from '../../components/ui/Section.astro';

const driveFileId = '1V1GrPS4ZI7MxPWQJEeawZXHrcB_mxAjP';
const previewUrl = `https://drive.google.com/file/d/${driveFileId}/preview`;
const downloadUrl = `https://drive.google.com/uc?id=${driveFileId}&export=download`;
---

<BaseLayout
  title="Dossier"
  description="Dossier institucional de la Orquesta Filarmónica Alimapu."
>
  <HeroSection title="Dossier" subtitle="Información institucional" height="sm" />

  <Section bg="white">
    <div class="max-w-4xl mx-auto">
      <p class="text-gray-600 text-lg mb-8 text-center">
        Conoce en detalle nuestra historia, repertorio, trayectoria y propuesta artística.
      </p>

      <!-- Botones de acción -->
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <a
          href={downloadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary-700 hover:bg-primary-800 text-white font-medium px-6 py-3 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Descargar Dossier
        </a>
        <a
          href="mailto:contacto@orquestaalimapu.cl"
          class="inline-flex items-center gap-2 border border-primary-700 text-primary-700 hover:bg-primary-50 font-medium px-6 py-3 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Solicitar información
        </a>
      </div>

      <!-- Visor PDF embebido -->
      <div class="bg-surface-50 rounded-xl overflow-hidden shadow-sm">
        <iframe
          src={previewUrl}
          class="w-full border-0"
          style="height: 80vh; min-height: 500px;"
          allow="autoplay"
          title="Dossier Alimapu 2025"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </Section>
</BaseLayout>
