---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import Section from '../components/ui/Section.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { musicGroupSchema } from '../utils/schema';
import { formatDateShort } from '../utils/date';

const base = import.meta.env.BASE_URL;

const today = new Date();

const allConcerts = await getCollection('conciertos', ({ data }) => !data.draft && !data.isCancelled);
const upcomingConcerts = allConcerts
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const allNews = await getCollection('noticias', ({ data }) => !data.draft);
const latestNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const schema = musicGroupSchema();
---

<BaseLayout
  title="Inicio"
  description="Orquesta Filarmónica Alimapu - Agrupación profesional de música clásica en la región de Valparaíso. Conciertos, audiciones y más."
  schema={schema}
>
  <!-- Hero -->
  <HeroSection
    title="Orquesta Filarmónica Alimapu"
    subtitle="Música desde la región de Valparaíso"
    height="lg"
    overlay="gradient"
    backgroundImage="/images/hero-home.webp"
  >
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center" style="animation: fade-in-up 0.6s ease-out 0.4s forwards; opacity: 0;">
      <a
        href={`${base}agenda/`}
        class="inline-flex items-center justify-center px-8 py-3 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg transition-colors"
      >
        Próximos Conciertos
      </a>
      <a
        href={`${base}sobre-nosotros/`}
        class="inline-flex items-center justify-center px-8 py-3 border-2 border-white/50 hover:border-white text-white font-semibold rounded-lg transition-colors"
      >
        Conócenos
      </a>
    </div>
  </HeroSection>

  <!-- Próximos Conciertos -->
  <Section bg="light">
    <SectionHeading
      title="Próximos Conciertos"
      subtitle="No te pierdas nuestras presentaciones"
    />
    {upcomingConcerts.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {upcomingConcerts.map((concert) => (
          <a
            href={`${base}agenda/${concert.id}/`}
            class="scroll-reveal group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden"
            data-home-concert={concert.data.date.toISOString().split('T')[0]}
          >
            <div class="bg-primary-950 p-4 text-center relative" data-home-concert-date={concert.data.date.toISOString().split('T')[0]}>
              <p class="text-accent-400 font-display text-lg font-bold">
                {formatDateShort(concert.data.date)}
              </p>
              <p class="text-gray-300 text-sm">{concert.data.time} hrs</p>
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl font-bold text-primary-950 group-hover:text-primary-700 transition-colors">
                {concert.data.title}
              </h3>
              <p class="mt-2 text-gray-600 text-sm">{concert.data.venue}</p>
              {concert.data.isFree && (
                <span class="mt-3 inline-block bg-green-100 text-green-800 text-xs font-medium px-2 py-1 rounded">
                  Entrada Liberada
                </span>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 bg-white rounded-lg shadow-sm scroll-reveal">
        <p class="text-gray-600 text-lg">No hay conciertos programados por el momento.</p>
        <p class="text-gray-500 mt-2">Síguenos en redes sociales para enterarte de nuevas fechas.</p>
      </div>
    )}
    <div class="text-center mt-10">
      <a
        href={`${base}agenda/`}
        class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-700 text-primary-700 hover:bg-primary-700 hover:text-white font-semibold rounded-lg transition-colors"
      >
        Ver toda la agenda
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </Section>

  <!-- Sobre Nosotros Preview -->
  <Section bg="white">
    <div class="grid md:grid-cols-2 gap-12 items-center scroll-reveal">
      <div>
        <SectionHeading
          title="Sobre Nosotros"
          subtitle="Música clásica accesible para todos"
        />
        <p class="text-gray-600 leading-relaxed mb-4">
          Somos una agrupación profesional, autogestionada y autónoma, comprometida con el
          desarrollo humano y cultural de la región de Valparaíso. Desde 2019 transformamos
          paradigmas, promoviendo la inclusión y el acceso universal a la música clásica.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Nuestros orígenes se remontan a 2017, cuando un grupo de músicos liderados por
          Danitza Villarroel realizó un concierto benéfico en apoyo a los damnificados por
          incendios forestales.
        </p>
        <a
          href={`${base}sobre-nosotros/`}
          class="inline-flex items-center text-primary-700 hover:text-primary-900 font-semibold transition-colors"
        >
          Conoce nuestra historia
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="bg-primary-950 rounded-2xl p-8 text-center">
        <p class="text-accent-400 font-display text-5xl font-bold mb-2">2019</p>
        <p class="text-gray-300">Año de fundación</p>
        <div class="mt-6 grid grid-cols-2 gap-4">
          <div>
            <p class="text-white font-display text-3xl font-bold">40+</p>
            <p class="text-gray-400 text-sm">Músicos</p>
          </div>
          <div>
            <p class="text-white font-display text-3xl font-bold">50+</p>
            <p class="text-gray-400 text-sm">Conciertos</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Últimas Noticias -->
  <Section bg="light">
    <SectionHeading
      title="Últimas Noticias"
      subtitle="Mantente informado sobre nuestras actividades"
    />
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {latestNews.map((news) => (
        <a
          href={`${base}noticias/${news.id}/`}
          class="scroll-reveal group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden"
        >
          <div class="bg-primary-950 p-4 text-center">
            <p class="text-accent-400 font-display text-lg font-bold">
              {formatDateShort(news.data.date)}
            </p>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-primary-950 group-hover:text-primary-700 transition-colors">
              {news.data.title}
            </h3>
            <p class="mt-2 text-gray-600 text-sm line-clamp-3">{news.data.description}</p>
            {news.data.tags && news.data.tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {news.data.tags.map((tag: string) => (
                  <span class="bg-primary-100 text-primary-800 text-xs font-medium px-2 py-1 rounded capitalize">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-10">
      <a
        href={`${base}noticias/`}
        class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-700 text-primary-700 hover:bg-primary-700 hover:text-white font-semibold rounded-lg transition-colors"
      >
        Ver todas las noticias
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </Section>

  <!-- CTA Audiciones -->
  <Section bg="dark">
    <div class="text-center scroll-reveal">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
        ¿Quieres ser parte de Alimapu?
      </h2>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto mb-8">
        Buscamos músicos comprometidos que quieran contribuir al desarrollo cultural de la región.
        Revisa nuestras audiciones abiertas.
      </p>
      <a
        href={`${base}audiciones/`}
        class="inline-flex items-center justify-center px-8 py-3 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg transition-colors"
      >
        Ver Audiciones
      </a>
    </div>
  </Section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const now = new Date();
      const todayStr = now.toLocaleDateString('en-CA');
      const todayTime = new Date(todayStr).getTime();
      let shown = 0;

      document.querySelectorAll('[data-home-concert]').forEach((card) => {
        const dateStr = (card as HTMLElement).dataset.homeConcert!;
        const concertTime = new Date(dateStr).getTime();
        const header = card.querySelector('[data-home-concert-date]');

        if (concertTime < todayTime) {
          (card as HTMLElement).style.display = 'none';
        } else if (shown < 3) {
          shown++;
          if (header) {
            if (dateStr === todayStr) {
              const badge = document.createElement('span');
              badge.textContent = '¡HOY!';
              badge.className = 'absolute top-2 right-2 bg-accent-500 text-white text-xs font-bold px-2 py-1 rounded-full animate-pulse';
              header.appendChild(badge);
            } else if (concertTime - todayTime <= 7 * 24 * 60 * 60 * 1000) {
              const badge = document.createElement('span');
              badge.textContent = 'Próximo';
              badge.className = 'absolute top-2 right-2 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full';
              header.appendChild(badge);
            }
          }
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  </script>

  <!-- Escúchanos -->
  <Section bg="white">
    <div class="text-center scroll-reveal">
      <SectionHeading
        title="Escúchanos"
        subtitle="Revive nuestras presentaciones"
        align="center"
      />
      <div class="max-w-3xl mx-auto">
        <a
          href="https://www.youtube.com/@orquestaalimapu"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Visita nuestro canal de YouTube
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
