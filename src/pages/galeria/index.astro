---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/ui/HeroSection.astro';
import Section from '../../components/ui/Section.astro';
import { formatDateShort } from '../../utils/date';
import { assetPath } from '../../utils/paths';

const albums = await getCollection('galeria');
const sortedAlbums = albums.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Galería"
  description="Fotos y videos de los conciertos y actividades de la Orquesta Filarmónica Alimapu."
>
  <HeroSection title="Galería" subtitle="Fotos y videos de nuestras presentaciones" height="sm" />

  <Section bg="light">
    {sortedAlbums.length > 0 ? (
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {sortedAlbums.map((album) => (
          <a
            href={`${import.meta.env.BASE_URL}galeria/${album.id}/`}
            class="scroll-reveal group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden"
          >
            <div class="aspect-video bg-primary-100 overflow-hidden">
              <img
                src={assetPath(album.data.coverImage)}
                alt={album.data.coverImageAlt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <p class="text-sm text-gray-500 mb-1">{formatDateShort(album.data.date)}</p>
              <h3 class="font-display text-lg font-bold text-primary-950 group-hover:text-primary-700 transition-colors">
                {album.data.title}
              </h3>
              {album.data.description && (
                <p class="mt-2 text-gray-600 text-sm">{album.data.description}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-600 text-lg">La galería estará disponible próximamente.</p>
      </div>
    )}
  </Section>
</BaseLayout>
