---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/ui/HeroSection.astro';
import Section from '../components/ui/Section.astro';
---

<BaseLayout
  title="Contacto"
  description="Contacta a la Orquesta Filarmónica Alimapu. Email, redes sociales y más."
>
  <HeroSection title="Contacto" subtitle="Escríbenos" height="sm" />

  <Section bg="light">
    <div class="max-w-2xl mx-auto">
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Email -->
        <div class="scroll-reveal bg-white rounded-xl shadow-sm p-6 text-center">
          <div class="w-12 h-12 mx-auto rounded-full bg-primary-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Email</h3>
          <a href="mailto:contacto@orquestaalimapu.cl" class="text-primary-700 hover:underline">
            contacto@orquestaalimapu.cl
          </a>
        </div>

        <!-- Ubicación -->
        <div class="scroll-reveal bg-white rounded-xl shadow-sm p-6 text-center">
          <div class="w-12 h-12 mx-auto rounded-full bg-primary-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Ubicación</h3>
          <p class="text-gray-600">Valparaíso, Chile</p>
        </div>
      </div>

      <!-- Redes sociales -->
      <div class="scroll-reveal mt-12 text-center">
        <h3 class="font-display text-xl font-bold text-primary-950 mb-6">Síguenos</h3>
        <div class="flex justify-center gap-6">
          <a
            href="https://www.instagram.com/orquestaalimapu/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-600 hover:text-pink-600 transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
            Instagram
          </a>
          <a
            href="https://www.youtube.com/@orquestaalimapu"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-600 hover:text-red-600 transition-colors"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
