---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  dark?: boolean;
}

const { title, subtitle, align = 'left', dark = false } = Astro.props;
---

<div class:list={['mb-10', align === 'center' && 'text-center']}>
  <h2
    class:list={[
      'font-display text-3xl md:text-4xl font-bold',
      dark ? 'text-white' : 'text-primary-950',
    ]}
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class:list={[
        'mt-3 text-lg max-w-2xl',
        dark ? 'text-gray-300' : 'text-gray-600',
        align === 'center' && 'mx-auto',
      ]}
    >
      {subtitle}
    </p>
  )}
  <div
    class:list={[
      'mt-4 w-16 h-1 rounded-full',
      dark ? 'bg-accent-400' : 'bg-accent-500',
      align === 'center' && 'mx-auto',
    ]}
  />
</div>
