---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: `${base}` },
  { label: 'Agenda', href: `${base}agenda/` },
  { label: 'Noticias', href: `${base}noticias/` },
  { label: 'Galería', href: `${base}galeria/` },
  // { label: 'Banda', href: `${base}banda/` },
  { label: 'Audiciones', href: `${base}audiciones/` },
  {
    label: 'Sobre Nosotros',
    href: `${base}sobre-nosotros/`,
    children: [
      { label: 'Equipo', href: `${base}sobre-nosotros/equipo/` },
      { label: 'Integrantes', href: `${base}sobre-nosotros/integrantes/` },
      { label: 'Dirección', href: `${base}sobre-nosotros/direccion/` },
      { label: 'Dossier', href: `${base}sobre-nosotros/dossier/` },
    ],
  },
  { label: 'Contacto', href: `${base}contacto/` },
];

function isActive(href: string): boolean {
  if (href === base) return currentPath === base;
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-primary-950/90 backdrop-blur-sm"
>
  <nav class="container mx-auto px-4 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href={base} class="flex items-center gap-3 text-white font-display text-xl font-bold">
      <span>Alimapu</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-1">
      {navItems.map((item) => (
        <li class="relative group">
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium rounded-md transition-colors',
              isActive(item.href)
                ? 'text-accent-400'
                : 'text-gray-200 hover:text-white hover:bg-white/10',
            ]}
          >
            {item.label}
            {item.children && (
              <svg class="inline-block w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {item.children && (
            <ul class="absolute top-full left-0 mt-1 w-48 bg-primary-950 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2 text-sm transition-colors',
                      isActive(child.href)
                        ? 'text-accent-400'
                        : 'text-gray-300 hover:text-white hover:bg-white/10',
                    ]}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden text-white p-2"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-primary-950 border-t border-white/10 pb-4"
  >
    <ul class="container mx-auto px-4 space-y-1 pt-4">
      {navItems.map((item) => (
        <>
          <li>
            <a
              href={item.href}
              class:list={[
                'block px-3 py-2 rounded-md text-sm font-medium',
                isActive(item.href)
                  ? 'text-accent-400 bg-white/5'
                  : 'text-gray-200 hover:text-white hover:bg-white/10',
              ]}
            >
              {item.label}
            </a>
          </li>
          {item.children?.map((child) => (
            <li>
              <a
                href={child.href}
                class:list={[
                  'block px-6 py-2 rounded-md text-sm',
                  isActive(child.href)
                    ? 'text-accent-400'
                    : 'text-gray-400 hover:text-white hover:bg-white/10',
                ]}
              >
                {child.label}
              </a>
            </li>
          ))}
        </>
      ))}
    </ul>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
